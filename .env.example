# ============================================================================
#  TravelON Transfer-Phone Bot — environment variables
#  Copy this file to ".env" for local runs. On Railway, set these as Variables.
#  NEVER commit a real .env file (it is git-ignored).
# ============================================================================

# --- TravelON credentials (REQUIRED) ----------------------------------------
# The bot logs in with these. On Railway add them as secret Variables.
TRAVELON_EMAIL=your-login@example.com
TRAVELON_PASSWORD=your-password

# Base site URL and key pages (override only if the site moves).
TRAVELON_BASE_URL=https://travelon.to
# Login page (TravelON is a Rails/Devise app; this is the Devise sign-in path).
TRAVELON_LOGIN_URL=https://travelon.to/admin/users/sign_in
# Requests / bookings list page (this is the page the manual workflow used).
TRAVELON_REQUESTS_URL=https://travelon.to/book/bundle/index

# --- Behaviour ---------------------------------------------------------------
# DRY_RUN=true  -> bot finds matching bookings and LOGS what it would send,
#                  but sends nothing. Start here. Flip to false when confident.
DRY_RUN=true

# Cron schedule (default: every 30 minutes). Uses CRON_TZ below.
CHECK_CRON=*/30 * * * *

# Run a single cycle then exit (useful for testing / Railway cron). true/false.
RUN_ONCE=false

# Timezone used for "today" date comparison and the cron schedule.
CRON_TZ=Europe/Kyiv

# Safety cap: never send more than this many messages in one cycle.
MAX_SENDS_PER_RUN=25

# --- Matching criteria -------------------------------------------------------
# Countries to act on (as shown in the "State" column, comma-separated).
TARGET_COUNTRIES=Греція,Болгарія,Албанія,Хорватія,Іспанія

# Statuses to keep (the bot unchecks everything else in the Status filter).
TARGET_STATUSES=Confirmed,Confirmed Print

# Only act on bookings whose "Date of request" (creation date) is today
# (in CRON_TZ) or later. Set to false to act on ALL listed confirmed bookings
# regardless of creation date (NOT recommended).
ONLY_TODAY=true

# --- The message -------------------------------------------------------------
# Department + message-subject template used in the chat composer.
MESSAGE_DEPARTMENT=Бронювання
MESSAGE_SUBJECT=Надання контактів водію автобуса
MESSAGE_TEXT=Шановні колеги, просимо надіслати телефон туристів для зв'язку з трансферменами. Дякуємо.
# Send to everyone (so the agent sees it) vs administrators-only. Keep "everyone".
MESSAGE_AUDIENCE=everyone

# --- Browser -----------------------------------------------------------------
HEADLESS=true
# Slow down actions by N ms (helps on flaky sites / debugging). 0 = full speed.
SLOWMO_MS=0
NAV_TIMEOUT_MS=45000

# Persisted data (sent-IDs store + screenshots). On Railway attach a Volume
# and point this at its mount path to survive restarts (optional but advised).
DATA_DIR=./data
SCREENSHOT_ON_ERROR=true

# --- Optional Telegram notifications -----------------------------------------
# If both are set, the bot posts a summary each cycle (great for dry-run).
# Create a bot via @BotFather, get the token; get your chat id via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging -----------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
